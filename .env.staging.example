# ============================================================================
# FLC BI — Staging Environment Template
# ============================================================================
# Copy to `.env.staging` and fill with values from the staging Supabase
# project. Staging uses its own Supabase project (separate from production
# and local) with its own rotated keys. Never commit filled `.env.staging`.
# ----------------------------------------------------------------------------

# Supabase (staging project, separate from production)
VITE_SUPABASE_URL=https://<staging-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<staging-anon-key>
VITE_SUPABASE_PROJECT_ID=<staging-project-ref>

# Error tracking — staging DSN should be a separate Sentry project or env tag
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

VITE_APP_ENV=staging
VITE_APP_URL=https://staging.flc-bi.example.com
VITE_HRMS_APP_URL=https://hrms-staging.flc-bi.example.com
VITE_APP_VERSION=

# ============================================================================
# Server-only (CI / edge function secrets; set via `supabase secrets set`)
# ============================================================================
SUPABASE_SERVICE_ROLE_KEY=<staging-service-role-key>

# Edge-function CORS allow-list — staging host only
ALLOWED_ORIGINS=https://staging.flc-bi.example.com

# Push-notification role gate (comma-separated role names).
NOTIFY_ROLES=super_admin,company_admin,general_manager,manager

# Seed script — used by scripts/seed-from-extract.ts against staging only
SEED_TARGET_ENV=staging
SEED_DRY_RUN=true
