# ─────────────────────────────────────────────────────────────────────────────
# Example env file for scripts/provision-supabase-env.sh
#
# COPY THIS FILE OUTSIDE THE REPO and fill in real values:
#     cp scripts/provision-supabase-env.env.example ~/flc-uat.env
#     chmod 600 ~/flc-uat.env
#     $EDITOR ~/flc-uat.env
#
# Then:
#     set -a; . ~/flc-uat.env; set +a
#     ./scripts/provision-supabase-env.sh
#
# NEVER commit a filled-in copy of this file. .gitignore already excludes .env*
# but this .example file is safe because every value is a placeholder.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project ref (the subdomain before .supabase.co)
SUPABASE_PROJECT_REF=wptainexktqgfuafzrdp

# Personal access token — https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_replace_me

# Database password — Dashboard → Project Settings → Database → Database password
SUPABASE_DB_PASSWORD=replace_me

# Service-role JWT — Dashboard → Project Settings → API → service_role
# Must decode to role="service_role". NEVER ship this to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ_replace_me

# Public origin of the deployed app (no trailing slash)
SITE_URL=https://uat.protonfookloi.com

# First admin account. If ADMIN_PASSWORD is set and the user doesn't exist yet,
# bootstrap-admin.ts will create them; otherwise it will only activate an
# existing auth user.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Human-readable tenant name. A slug will be derived for companies.id.
COMPANY_NAME=Fook Loi Group
