# Example env file for scripts/configure-supabase-auth-smtp.sh
#
# Usage:
#   cp scripts/configure-supabase-auth-smtp.env.example ~/flc-bi-smtp.env
#   chmod 600 ~/flc-bi-smtp.env
#   edit ~/flc-bi-smtp.env
#   set -a && source ~/flc-bi-smtp.env && set +a
#   bash scripts/configure-supabase-auth-smtp.sh /srv/flc-bi

APP_URL=https://ubs.protonfookloi.com
HRMS_APP_URL=https://hrms.protonfookloi.com

AUTH_SMTP_HOST=smtp.resend.com
AUTH_SMTP_PORT=587
AUTH_SMTP_USER=resend
AUTH_SMTP_PASS=replace-with-your-relay-api-key-or-password
AUTH_SMTP_ADMIN_EMAIL=noreply@protonfookloi.com
AUTH_SMTP_SENDER_NAME=UBS

SYSTEMD_ENV_FILE=/etc/flc-bi/supabase.env
RESTART_SUPABASE_SERVICE=1