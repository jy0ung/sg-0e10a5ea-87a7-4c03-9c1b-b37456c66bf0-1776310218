# ============================================================================
# FLC BI — Environment Variables
# ============================================================================
# Copy this file to `.env.local` for local dev. Never commit `.env.local`.
# All VITE_* variables are inlined into the client bundle at build time —
# only put PUBLIC values here. Server-only secrets must be set separately in
# the Supabase project dashboard or CI secret manager.
# ----------------------------------------------------------------------------

# Supabase (client-side, safe to expose)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PROJECT_ID=

# Error tracking (optional). Leave empty to run in local-only mode.
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Build/runtime environment name used in logs and Sentry tags.
# One of: development | staging | production
VITE_APP_ENV=development

# App public URL (used for absolute links in emails, etc.)
VITE_APP_URL=http://localhost:3000

# Optional dedicated HRMS app URL used by the main app launcher.
# Leave empty to use the same-origin /hrms/ deployment.
VITE_HRMS_APP_URL=
VITE_APP_VERSION=dev

# ============================================================================
# Server-only (DO NOT prefix with VITE_; consumed by scripts and edge fns)
# ============================================================================
# Used by scripts/seed-from-extract.ts and local admin utilities.
SUPABASE_SERVICE_ROLE_KEY=

# Used by supabase/config.toml when sending auth mail via Resend SMTP.
RESEND_API_KEY=

# Edge-function CORS allow-list (comma-separated, no trailing slash).
# Must include every origin your frontend is served from.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Push-notification role gate (comma-separated role names).
NOTIFY_ROLES=super_admin,company_admin,general_manager,manager

# Phase 5 DMS sync placeholders. These are backend-only values for local scripts
# or edge-function secrets. Never prefix them with VITE_ and never put real
# Proton credentials in a committed file.
DMS_API_BASE_URL=https://dcs-api.proton.com
DMS_CLIENT_ID=
DMS_CLIENT_SECRET=
DMS_SIGNING_KEY=
DMS_TOKEN_URL=
DMS_DEFAULT_COMPANY_ID=
