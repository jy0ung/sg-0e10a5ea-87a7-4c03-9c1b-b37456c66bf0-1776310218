# FLC HRMS Mobile — environment variables
# Copy this file to .env and fill in the values.
# Both VITE_ variables are required.

# Supabase project URL (same as the web app)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (same as the web app)
VITE_SUPABASE_ANON_KEY=your-anon-key-here
