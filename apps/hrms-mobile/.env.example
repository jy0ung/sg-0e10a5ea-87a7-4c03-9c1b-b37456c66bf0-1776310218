# FLC HRMS Mobile — environment variables
# Copy this file to .env and fill in the values.
# Both VITE_ variables are required.

# HRMS Supabase project URL. While HRMS is detached, this must not point to the UBS project.
VITE_SUPABASE_URL=https://your-project.supabase.co

# HRMS Supabase anon/public key.
VITE_SUPABASE_ANON_KEY=your-anon-key-here
