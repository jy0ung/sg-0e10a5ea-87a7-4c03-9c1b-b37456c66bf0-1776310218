{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "resolveJsonModule": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@flc/types": ["./packages/types/src/index.ts"],
      "@flc/supabase": ["./packages/supabase/src/index.ts"],
      "@flc/hrms-schemas": ["./packages/hrms-schemas/src/index.ts"]
    },
    "skipLibCheck": true,
    "strict": false,
    "strictNullChecks": true,
    // Phase 2 debt (tracked in IMPLEMENTATION_MAP.md):
    //   - noImplicitAny — requires audit of ~30 implicit-any sites in services
    //   - noUnusedLocals, noUnusedParameters — deferred until pre-commit tighten
    // Package-exported flags (already on):
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": true,
    "noFallthroughCasesInSwitch": true,
    "target": "ES2020",
    "types": [
      "vitest/globals"
    ],
    "useDefineForClassFields": true
  },
  "include": [
    "src",
    "packages/*/src"
  ]
}