{
  "name": "flc-bi",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:budget": "npm run build && npm run bundle:budget",
    "bundle:budget": "tsx scripts/check-bundle-budget.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && npm run check:rpc-contracts && npm run check:rpc-frontend && npm run check:workflow-boundary && npm run check:legacy-approval-debt && npm run check:route-registry-parity && npm run check:production-smoke-registry && npm run check:shell-module-boundary && npm run check:hrms-registry-boundary && npm run check:page-data-boundary && npm run check:unavailable-state-registry && npm run check:ui-boundary && npm run check:platform-service-boundary && npm run check:hrms-service-boundary && npm run check:auth-service-boundary && npm run check:internal-request-service-boundary",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:rpc-contracts": "tsx scripts/check-rpc-contracts.ts",
    "check:rpc-frontend": "tsx scripts/check-rpc-frontend-vs-migrations.ts",
    "check:workflow-boundary": "tsx scripts/check-workflow-boundary.ts",
    "check:legacy-approval-debt": "tsx scripts/check-legacy-approval-debt.ts",
    "check:route-registry-parity": "tsx scripts/check-route-registry-parity.ts",
    "check:production-smoke-registry": "tsx scripts/check-production-smoke-registry.ts",
    "check:shell-module-boundary": "tsx scripts/check-shell-module-boundary.ts",
    "check:hrms-registry-boundary": "tsx scripts/check-hrms-registry-boundary.ts",
    "check:page-data-boundary": "tsx scripts/check-page-data-boundary.ts",
    "check:unavailable-state-registry": "tsx scripts/check-unavailable-state-registry.ts",
    "check:ui-boundary": "tsx scripts/check-ui-boundary.ts",
    "check:platform-service-boundary": "tsx scripts/check-platform-service-boundary.ts",
    "check:hrms-service-boundary": "tsx scripts/check-hrms-service-boundary.ts",
    "check:auth-service-boundary": "tsx scripts/check-auth-service-boundary.ts",
    "check:internal-request-service-boundary": "tsx scripts/check-internal-request-service-boundary.ts",
    "security:no-service-role": "tsx scripts/check-no-service-role.ts",
    "security:smoke": "tsx scripts/security-smoke.ts",
    "test:rls:seed": "tsx scripts/seed-rls-users.ts",
    "test:rls:cleanup": "tsx scripts/seed-rls-users.ts --cleanup",
    "test:rls": "RLS_E2E=1 vitest run --config vitest.rls.config.ts",
    "bootstrap:admin": "tsx scripts/bootstrap-admin.ts",
    "provision:env": "bash scripts/provision-supabase-env.sh",
    "security:edge-functions": "tsx scripts/check-edge-functions.ts",
    "verify:production": "tsx scripts/verify-production-deploy.ts",
    "smoke:production": "tsx scripts/smoke-production-modules.ts",
    "health:rpc-canaries": "tsx scripts/health-rpc-canaries.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@flc/auth": "*",
    "@flc/hrms-schemas": "*",
    "@flc/hrms-services": "*",
    "@flc/internal-requests": "*",
    "@flc/platform-services": "*",
    "@flc/shell": "*",
    "@flc/supabase": "*",
    "@flc/types": "*",
    "@flc/ui": "*",
